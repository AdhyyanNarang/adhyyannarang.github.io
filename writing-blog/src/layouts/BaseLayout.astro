---
import '../layouts/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Writing — Adhyyan Narang', description = 'Research notes on AI safety, game theory, and the systems we build' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Favicon: simple gold diamond -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><polygon points='50,10 90,50 50,90 10,50' fill='none' stroke='%23c9a96e' stroke-width='5'/></svg>" />
</head>
<body>
  <div class="grain-overlay"></div>
  <slot />
</body>
</html>
